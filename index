<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEX — F1 Card & Quiz Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --red: #E8002D;
  --red-dark: #a8001f;
  --gold: #FFD700;
  --gold-dim: #c9a800;
  --carbon: #0a0a0a;
  --surface: #111111;
  --surface2: #1a1a1a;
  --surface3: #222222;
  --border: #2a2a2a;
  --text: #f0f0f0;
  --text-dim: #888;
  --green: #00c853;
  --blue: #2979ff;
  --purple: #aa00ff;
  --teal: #00bcd4;
  --orange: #FF8C00;
  --bronze: #CD7F32;
  --silver: #C0C0C0;
  --diamond: #00FFFF;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--carbon);color:var(--text);font-family:'Barlow',sans-serif;overflow-x:hidden}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--carbon)}
::--webkit-scrollbar-thumb{background:var(--red);border-radius:2px}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:999;background:rgba(10,10,10,0.97);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;height:56px;gap:4px;overflow-x:auto}
.nav-logo{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.6rem;color:var(--red);letter-spacing:2px;margin-right:12px;cursor:pointer;white-space:nowrap;flex-shrink:0}
.nav-logo span{color:var(--text)}
.nav-btn{background:none;border:none;color:var(--text-dim);font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:.95rem;letter-spacing:1px;padding:8px 10px;cursor:pointer;border-radius:4px;transition:all .2s;text-transform:uppercase;white-space:nowrap;flex-shrink:0}
.nav-btn:hover,.nav-btn.active{color:var(--text);background:var(--surface2)}
.nav-btn.active{color:var(--red);border-bottom:2px solid var(--red)}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:10px;flex-shrink:0}
.coins-display{display:flex;align-items:center;gap:6px;background:var(--surface2);border:1px solid var(--gold-dim);border-radius:20px;padding:6px 14px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:var(--gold);cursor:pointer;transition:all .2s}
.coins-display:hover{border-color:var(--gold)}

/* PAGES */
.page{display:none;padding:72px 0 40px}
.page.active{display:block}

/* ===================== HOME PAGE ===================== */
.hero{position:relative;min-height:90vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;overflow:hidden;padding:20px}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse at center top, rgba(232,0,45,0.18) 0%, transparent 65%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:40px 40px}
.hero-speedlines{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.speedline{position:absolute;height:1px;background:linear-gradient(90deg,transparent,rgba(232,0,45,0.3),transparent);animation:speedlineAnim 3s linear infinite}
@keyframes speedlineAnim{0%{transform:translateX(-100%)}100%{transform:translateX(200%)}}
.hero-title{position:relative;font-family:'Barlow Condensed',sans-serif;font-weight:900;line-height:0.88;text-transform:uppercase;letter-spacing:-2px}
.hero-title .line1{color:var(--text);display:block;font-size:clamp(2.5rem,7vw,5.5rem)}
.hero-title .line2{color:var(--red);display:block;font-size:clamp(5rem,14vw,11rem);text-shadow:0 0 60px rgba(232,0,45,0.4)}
.hero-sub{position:relative;font-size:1.05rem;color:var(--text-dim);margin:24px 0 32px;max-width:500px;line-height:1.6}
.hero-btns{position:relative;display:flex;gap:12px;flex-wrap:wrap;justify-content:center}
.btn{display:inline-flex;align-items:center;gap:8px;padding:13px 24px;border-radius:4px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border:none;transition:all .2s}
.btn-red{background:var(--red);color:#fff}
.btn-red:hover{background:#ff1a45;transform:translateY(-1px)}
.btn-outline{background:transparent;color:var(--text);border:1px solid var(--border)}
.btn-outline:hover{border-color:var(--red);color:var(--red)}
.btn-gold{background:var(--gold);color:#000}
.btn-gold:hover{background:#ffe033}
.btn-green{background:var(--green);color:#000}
.btn-green:hover{background:#00e664}
.btn-blue{background:var(--blue);color:#fff}
.btn-blue:hover{background:#448aff}
.btn-sm{padding:7px 14px;font-size:.85rem}

/* HOME STATS BAR */
.home-stats-bar{position:relative;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.home-stat{background:var(--carbon);padding:20px;text-align:center}
.home-stat-val{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2rem;color:var(--red)}
.home-stat-label{font-size:.75rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;margin-top:4px}

/* LIVE STANDINGS TICKER */
.standings-ticker{background:var(--surface);border-bottom:1px solid var(--border);padding:12px 24px;display:flex;align-items:center;gap:16px;overflow:hidden}
.ticker-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:var(--red);text-transform:uppercase;letter-spacing:1px;white-space:nowrap;flex-shrink:0}
.ticker-track{display:flex;gap:24px;animation:tickerScroll 30s linear infinite;white-space:nowrap}
.ticker-track:hover{animation-play-state:paused}
@keyframes tickerScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.ticker-item{display:flex;align-items:center;gap:6px;font-family:'Share Tech Mono',monospace;font-size:.8rem;color:var(--text-dim)}
.ticker-pos{color:var(--gold);font-weight:700;min-width:20px}
.ticker-name{color:var(--text)}
.ticker-pts{color:var(--text-dim)}

/* FEATURE STRIP */
.feature-strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1px;background:var(--border);border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin-top:0}
.feature-item{background:var(--carbon);padding:28px 20px;display:flex;flex-direction:column;align-items:center;gap:10px;text-align:center;cursor:pointer;transition:background .2s}
.feature-item:hover{background:var(--surface)}
.feature-icon{font-size:2rem}
.feature-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem;letter-spacing:1px;text-transform:uppercase}
.feature-desc{font-size:.8rem;color:var(--text-dim);line-height:1.4}

/* SECTION HEADERS */
.section{max-width:1100px;margin:0 auto;padding:36px 20px}
.section-header{display:flex;align-items:baseline;gap:16px;margin-bottom:28px;padding-bottom:14px;border-bottom:1px solid var(--border)}
.section-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2rem;text-transform:uppercase;letter-spacing:1px}
.section-subtitle{font-size:.85rem;color:var(--text-dim)}

/* NEW: PROFILE & LEADERBOARD */
.profile-header{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;margin-bottom:24px;display:flex;align-items:center;gap:24px;flex-wrap:wrap}
.profile-avatar{font-size:4.5rem;width:100px;height:100px;background:var(--surface2);border-radius:50%;display:flex;align-items:center;justify-content:center;border:4px solid var(--red)}
.profile-info h2{font-family:'Barlow Condensed',sans-serif;font-size:2.2rem;margin-bottom:4px}
.leaderboard-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
.leaderboard-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:18px}
.leaderboard-card .rank{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.5rem;color:var(--gold)}

/* ACHIEVEMENTS */
.achievements-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:14px}
.achievement{background:var(--surface);border:2px solid var(--border);border-radius:10px;padding:16px;text-align:center;cursor:pointer;transition:all .2s}
.achievement.unlocked{border-color:var(--gold);background:rgba(255,215,0,0.08)}
.achievement-icon{font-size:3rem;margin-bottom:8px}
.achievement-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem}

/* NEW: TIERED PACKS */
.pack-tier{display:flex;gap:8px;justify-content:center;margin-bottom:20px}
.tier-btn{padding:10px 20px;border-radius:6px;font-weight:700;cursor:pointer;border:2px solid transparent}
.tier-btn.bronze{border-color:var(--bronze);color:var(--bronze)}
.tier-btn.silver{border-color:var(--silver);color:var(--silver)}
.tier-btn.gold{border-color:var(--gold);color:var(--gold)}
.tier-btn.diamond{border-color:var(--diamond);color:var(--diamond)}
.tier-btn.active{background:rgba(255,255,255,0.1);box-shadow:0 0 15px currentColor}

/* QUIZ */
.quiz-categories{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:14px;margin-bottom:36px}
.quiz-cat{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:22px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.quiz-cat:hover{border-color:var(--red);transform:translateY(-2px)}
.quiz-cat::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--cat-color,var(--red))}
.quiz-cat-icon{font-size:1.8rem;margin-bottom:10px;display:block}
.quiz-cat-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.25rem;text-transform:uppercase;margin-bottom:4px}
.quiz-cat-desc{font-size:.8rem;color:var(--text-dim)}
.quiz-cat-reward{margin-top:10px;font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--gold)}
.quiz-container{max-width:700px;margin:0 auto}
.quiz-progress{display:flex;align-items:center;gap:12px;margin-bottom:24px}
.quiz-progress-bar{flex:1;height:4px;background:var(--surface3);border-radius:2px;overflow:hidden}
.quiz-progress-fill{height:100%;background:var(--red);transition:width .4s}
.quiz-q-num{font-family:'Share Tech Mono',monospace;font-size:.82rem;color:var(--text-dim)}
.quiz-timer{font-family:'Share Tech Mono',monospace;font-size:.82rem;color:var(--gold);margin-left:auto}
.quiz-question{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:28px;margin-bottom:18px}
.quiz-q-text{font-size:1.15rem;line-height:1.5;font-weight:500}
.quiz-options{display:flex;flex-direction:column;gap:9px}
.quiz-option{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:14px 18px;cursor:pointer;font-size:.97rem;text-align:left;color:var(--text);transition:all .2s;display:flex;align-items:center;gap:12px}
.quiz-option:hover:not(.locked){border-color:var(--red);background:var(--surface3)}
.quiz-option.correct{background:rgba(0,200,83,0.15);border-color:var(--green);color:var(--green)}
.quiz-option.wrong{background:rgba(232,0,45,0.1);border-color:var(--red)}
.quiz-option.locked{cursor:default}
.quiz-option-key{font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--text-dim);width:20px;flex-shrink:0}
.quiz-result{text-align:center;padding:40px;background:var(--surface);border:1px solid var(--border);border-radius:8px}
.quiz-result-score{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:4rem;color:var(--gold)}
.quiz-result-earned{font-size:1.1rem;margin:8px 0 24px;color:var(--text-dim)}

/* CARDS PAGE - UPDATED TIERS */
.shop-tabs{display:flex;gap:2px;background:var(--surface);border-radius:6px;padding:4px;margin-bottom:20px;width:fit-content}
.shop-tab{padding:7px 18px;border-radius:4px;cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.9rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-dim);transition:all .2s;border:none;background:none}
.shop-tab.active{background:var(--red);color:#fff}

.shop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:18px;margin-bottom:36px}
.pack-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;cursor:pointer;transition:all .2s;position:relative}
.pack-card:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,0.5)}
.pack-banner{height:110px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;position:relative}
.pack-type-badge{position:absolute;top:8px;left:8px;font-family:'Share Tech Mono',monospace;font-size:.65rem;padding:2px 6px;border-radius:3px;text-transform:uppercase;letter-spacing:1px;background:rgba(0,0,0,0.6)}
.pack-tier-badge{position:absolute;top:8px;right:8px;font-size:.7rem;padding:2px 8px;border-radius:20px;font-weight:700}
.bronze-badge{background:var(--bronze);color:#fff}
.silver-badge{background:var(--silver);color:#000}
.gold-badge{background:var(--gold);color:#000}
.diamond-badge{background:var(--diamond);color:#000}

.card{border-radius:12px;overflow:hidden;position:relative;cursor:pointer;transition:transform .2s}
.card:hover{transform:scale(1.03)}
.card-inner{padding:18px;position:relative;z-index:1}
.card-team-stripe{height:6px;width:100%;position:absolute;top:0;left:0}
.card-rarity-badge{position:absolute;top:12px;right:12px;font-family:'Share Tech Mono',monospace;font-size:.68rem;padding:3px 8px;border-radius:3px;text-transform:uppercase;letter-spacing:1px}
.rarity-common{background:var(--surface3);color:var(--text-dim)}
.rarity-rare{background:rgba(41,121,255,0.2);color:var(--blue);border:1px solid var(--blue)}
.rarity-epic{background:rgba(170,0,255,0.2);color:var(--purple);border:1px solid var(--purple)}
.rarity-legendary{background:rgba(255,215,0,0.2);color:var(--gold);border:1px solid var(--gold)}
.card-number{font-family:'Share Tech Mono',monospace;font-size:.72rem;color:rgba(255,255,255,0.2);margin-top:22px}
.card-name{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.5rem;text-transform:uppercase;letter-spacing:1px;line-height:1}
.card-nation{font-size:.78rem;color:var(--text-dim);margin:2px 0 10px}
.card-stats{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-top:10px}
.card-stat{background:rgba(0,0,0,0.3);border-radius:4px;padding:5px 8px;font-family:'Share Tech Mono',monospace}
.card-stat-label{font-size:.58rem;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:1px}
.card-stat-val{font-size:.95rem;font-weight:700;color:var(--text)}
.card-overall{position:absolute;bottom:14px;right:14px;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.2rem;line-height:1}
.card.legendary-bg{background:linear-gradient(135deg,#1a1100 0%,#2a1e00 50%,#1a1100 100%)}
.card.epic-bg{background:linear-gradient(135deg,#0d0020 0%,#1a0035 50%,#0d0020 100%)}
.card.rare-bg{background:linear-gradient(135deg,#001230 0%,#001a4a 50%,#001230 100%)}
.card.common-bg{background:var(--surface)}

/* COLLECTION */
.collection-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px}
.collection-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;cursor:pointer;transition:all .2s;position:relative}
.collection-card:hover{transform:translateY(-3px)}
.collection-card .card-inner{padding:14px}
.collection-card .card-name{font-size:1.1rem}
.duplicate-badge{position:absolute;top:8px;left:8px;background:rgba(232,0,45,0.85);color:#fff;font-family:'Share Tech Mono',monospace;font-size:.65rem;padding:2px 6px;border-radius:3px;z-index:2}
.sell-btn{width:100%;background:var(--surface3);border:none;border-top:1px solid var(--border);color:var(--text-dim);font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:.8rem;text-transform:uppercase;letter-spacing:.5px;padding:8px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px}
.sell-btn:hover{background:rgba(232,0,45,0.15);color:var(--red)}
.empty-collection{text-align:center;padding:60px 20px;color:var(--text-dim);grid-column:1/-1}
.empty-collection .icon{font-size:3rem;margin-bottom:14px}
.collection-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;align-items:center}

/* PACK OPENING OVERLAY */
.pack-opening-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.97);z-index:2000;display:none;align-items:center;justify-content:center;flex-direction:column;gap:20px}
.pack-opening-overlay.open{display:flex}
.pack-opening-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.8rem;text-transform:uppercase;letter-spacing:2px;color:var(--gold)}
.pack-animation{font-size:5rem;animation:packSpin 0.6s ease-out forwards}
@keyframes packSpin{0%{transform:scale(0) rotate(-180deg);opacity:0}100%{transform:scale(1) rotate(0deg);opacity:1}}
.reveal-cards{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;max-width:900px;padding:0 16px}
.reveal-card{animation:cardReveal .4s ease-out backwards;border-radius:10px;overflow:hidden;width:150px;cursor:pointer;position:relative}
.reveal-card.face-down{background:var(--surface2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;min-height:120px;font-size:2rem}
@keyframes cardReveal{0%{transform:translateY(40px) rotateY(90deg);opacity:0}100%{transform:translateY(0) rotateY(0);opacity:1}}
.pick-card-instruction{font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px}
.picked-card-display{text-align:center}
.reveal-card.selectable:hover{transform:scale(1.06);box-shadow:0 0 20px rgba(232,0,45,0.4)}

/* SIMULATION - TEAM PRINCIPAL MODE */
.sim-setup{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:24px}
.sim-team-builder{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin:16px 0}
.sim-slot{background:var(--surface2);border:2px dashed var(--border);border-radius:8px;padding:18px;text-align:center;cursor:pointer;min-height:110px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;transition:border-color .2s}
.sim-slot:hover{border-color:var(--red)}
.sim-slot.filled{border-style:solid;border-color:var(--border)}
.sim-slot-label{font-size:.72rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;font-family:'Barlow Condensed',sans-serif;font-weight:600}
.sim-slot-driver{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.05rem;text-transform:uppercase}
.sim-slot-rating{font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--gold)}
.sim-results{background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden}
.sim-race-result{border-bottom:1px solid var(--border)}
.sim-race-header{padding:11px 18px;background:var(--surface2);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.92rem;text-transform:uppercase;letter-spacing:1px;display:flex;align-items:center;gap:10px}
.sim-podium-row{display:flex;align-items:center;gap:10px;padding:9px 18px;font-size:.88rem}
.sim-pos{font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--text-dim);width:24px}
.sim-pos.p1{color:var(--gold)}
.sim-pos.p2{color:#c0c0c0}
.sim-pos.p3{color:#cd7f32}
.standings-table{width:100%;border-collapse:collapse}
.standings-table th{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.82rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);padding:10px 14px;text-align:left;border-bottom:1px solid var(--border)}
.standings-table td{padding:9px 14px;border-bottom:1px solid rgba(255,255,255,0.04);font-size:.87rem}
.standings-table tr:hover td{background:var(--surface2)}
.pts-badge{background:var(--red);color:#fff;font-family:'Share Tech Mono',monospace;font-size:.78rem;padding:2px 7px;border-radius:3px}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:1500;display:none;align-items:center;justify-content:center;padding:16px}
.modal-overlay.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:12px;width:100%;max-width:520px;max-height:85vh;overflow-y:auto}
.modal-header{display:flex;align-items:center;gap:12px;padding:18px;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--surface);z-index:1}
.modal-title{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;text-transform:uppercase;flex:1}
.modal-close{background:none;border:none;color:var(--text-dim);font-size:1.4rem;cursor:pointer;padding:4px}
.modal-body{padding:18px}

/* TOAST */
.toast-container{position:fixed;bottom:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:7px}
.toast{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:11px 16px;font-size:.88rem;display:flex;align-items:center;gap:9px;animation:toastIn .3s ease-out;min-width:200px;max-width:320px}
.toast.gold{border-color:var(--gold-dim)}
.toast.green{border-color:var(--green)}
.toast.red{border-color:var(--red)}
@keyframes toastIn{from{transform:translateX(100px);opacity:0}to{transform:translateX(0);opacity:1}}

/* CARD SELECT MODAL */
.card-select-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:9px;max-height:380px;overflow-y:auto}
.card-select-item{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:10px;cursor:pointer;transition:all .2s;text-align:center}
.card-select-item:hover,.card-select-item.selected{border-color:var(--red)}
.card-select-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.9rem;text-transform:uppercase}
.card-select-rat{font-family:'Share Tech Mono',monospace;font-size:.72rem;color:var(--gold)}

/* TABS */
.tabs{display:flex;gap:2px;background:var(--surface);border-radius:6px;padding:4px;margin-bottom:22px;width:fit-content;flex-wrap:wrap}
.tab{padding:7px 18px;border-radius:4px;cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:.9rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-dim);transition:all .2s;border:none;background:none}
.tab.active{background:var(--red);color:#fff}

/* MISC */
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.animate-pulse{animation:pulse 2s infinite}
.badge{display:inline-block;padding:2px 7px;border-radius:3px;font-size:.68rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
.badge-gold{background:rgba(255,215,0,0.15);color:var(--gold);border:1px solid rgba(255,215,0,0.3)}
.badge-red{background:rgba(232,0,45,0.15);color:var(--red);border:1px solid rgba(232,0,45,0.3)}
.badge-green{background:rgba(0,200,83,0.15);color:var(--green);border:1px solid rgba(0,200,83,0.3)}
.divider{height:1px;background:var(--border);margin:20px 0}

.overall-ring{display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:50%;border:3px solid;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.3rem;flex-shrink:0}
.stat-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.stat-bar-label{font-size:.75rem;color:var(--text-dim);width:70px;text-transform:uppercase;letter-spacing:.5px;font-family:'Share Tech Mono',monospace}
.stat-bar-track{flex:1;height:6px;background:var(--surface3);border-radius:3px;overflow:hidden}
.stat-bar-fill{height:100%;border-radius:3px;transition:width .6s ease}
.stat-bar-val{font-family:'Share Tech Mono',monospace;font-size:.75rem;color:var(--text-dim);width:24px;text-align:right}

@media(max-width:600px){
  .hero-title .line2{font-size:clamp(3.5rem,18vw,8rem)}
  .sim-team-builder{grid-template-columns:1fr}
  nav{padding:0 8px}
  .nav-btn{padding:6px 7px;font-size:.8rem}
  .home-stats-bar{grid-template-columns:1fr 1fr}
}

/* EASTER EGG */
.easter-egg-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.97);z-index:9998;display:none;align-items:center;justify-content:center;flex-direction:column;gap:16px;text-align:center}
.easter-egg-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2.5rem,8vw,5rem);text-transform:uppercase;letter-spacing:2px;color:var(--gold);text-shadow:0 0 40px rgba(255,215,0,0.5)}
.easter-egg-subtitle{font-size:1.1rem;color:var(--text-dim);max-width:500px;line-height:1.6}
.easter-egg-coins{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3rem;color:var(--green);animation:pulse 1s ease-in-out 3}
</style>
</head>
